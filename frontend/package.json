{
  "name": "yarcogroup-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "YARCO GROUP — корпоративный сайт-витрина (v1). React + TS + Vite, дизайн из брендбука, разметка GRACE.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
